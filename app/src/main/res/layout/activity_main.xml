<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/toolbar_bg"
            android:elevation="0dp"
            app:titleTextColor="@color/toolbar_text"
            app:subtitleTextColor="@color/toolbar_subtitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:gravity="end"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btn_undo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Undo"
                    android:src="@drawable/ic_undo"
                    android:tint="@color/toolbar_icon" />

                <ImageButton
                    android:id="@+id/btn_redo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Redo"
                    android:src="@drawable/ic_redo"
                    android:tint="@color/toolbar_icon" />

                <ImageButton
                    android:id="@+id/btn_search"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Search"
                    android:src="@drawable/ic_search"
                    android:tint="@color/toolbar_icon" />

                <ImageButton
                    android:id="@+id/btn_save"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Save"
                    android:src="@drawable/ic_save"
                    android:tint="@color/toolbar_icon" />

                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Settings"
                    android:src="@drawable/ic_settings"
                    android:tint="@color/toolbar_icon" />

                <ImageButton
                    android:id="@+id/btn_terminal"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Terminal"
                    android:src="@drawable/ic_terminal"
                    android:tint="@color/toolbar_icon" />

                <ImageButton
                    android:id="@+id/btn_extensions"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Extensions"
                    android:src="@drawable/ic_extensions"
                    android:tint="@color/toolbar_icon" />
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>

        <!-- Toolbar bottom border -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/toolbar_border" />

        <!-- Tabs Bar -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_tabs"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@color/tabs_bg"
            android:visibility="gone" />

        <!-- Tabs bottom border -->
        <View
            android:id="@+id/v_tabs_border"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/toolbar_border"
            android:visibility="gone" />

        <!-- Editor Area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <WebView
                android:id="@+id/editor_web_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <!-- Placeholder when no file is open -->
            <LinearLayout
                android:id="@+id/tv_editor_placeholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/editor_bg"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VSCode Android"
                    android:textColor="#3C3C3C"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Abre el explorador y selecciona una carpeta"
                    android:textColor="@color/placeholder_text"
                    android:textSize="13sp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Status Bar -->
        <LinearLayout
            android:id="@+id/status_bar"
            android:layout_width="match_parent"
            android:layout_height="22dp"
            android:background="@color/statusbar_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tv_status_branch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="4dp"
                android:text="No folder"
                android:textColor="@color/statusbar_text"
                android:textSize="11sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_status_lang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/statusbar_text"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_status_encoding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="UTF-8"
                android:textColor="@color/statusbar_text"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Navigation Drawer (File Explorer) -->
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/explorer_bg"
        android:orientation="vertical">

        <!-- Explorer Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/explorer_header_bg"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="4dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="EXPLORADOR"
                    android:textColor="@color/explorer_header_text"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_new_file"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="New File"
                    android:src="@drawable/ic_new_file"
                    android:tint="@color/explorer_icon" />

                <ImageButton
                    android:id="@+id/btn_new_folder"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="New Folder"
                    android:src="@drawable/ic_new_folder"
                    android:tint="@color/explorer_icon" />

                <ImageButton
                    android:id="@+id/btn_refresh"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Refresh"
                    android:src="@drawable/ic_refresh"
                    android:tint="@color/explorer_icon" />

                <ImageButton
                    android:id="@+id/btn_open_folder"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Open Folder"
                    android:src="@drawable/ic_folder_open"
                    android:tint="@color/accent" />
            </LinearLayout>
        </LinearLayout>

        <!-- Explorer header bottom border -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/explorer_border" />

        <!-- Current folder name -->
        <TextView
            android:id="@+id/tv_folder_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/explorer_bg"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text=""
            android:textColor="@color/explorer_header_text"
            android:textSize="12sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="start"
            android:visibility="gone" />

        <!-- File Tree -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_files"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/tv_empty_explorer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sin carpeta abierta"
                android:textColor="#858585"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="Toca el ícono de carpeta\npara abrir una"
                android:textAlignment="center"
                android:textColor="@color/placeholder_text"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
