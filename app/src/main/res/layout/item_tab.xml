<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:minWidth="80dp"
    android:maxWidth="160dp"
    android:orientation="vertical">

    <!-- Active tab top border indicator -->
    <View
        android:id="@+id/v_tab_active_indicator"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/tab_active_border"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="4dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_tab_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="middle"
            android:maxLines="1"
            android:textSize="12sp" />

        <!-- Modified dot (replaces close btn when modified) -->
        <View
            android:id="@+id/v_modified_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/dot_modified"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btn_tab_close"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close tab"
            android:src="@drawable/ic_close"
            android:tint="@color/tab_close_icon" />
    </LinearLayout>
</LinearLayout>
