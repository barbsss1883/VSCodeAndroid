<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E1E"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/extensions_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#252526"
        app:title="Extensiones"
        app:titleTextColor="#CCCCCC" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout_extensions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#252526"
        app:tabTextColor="#888888"
        app:tabSelectedTextColor="#CCCCCC"
        app:tabIndicatorColor="#0078D4">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disponibles" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Instaladas" />
    </com.google.android.material.tabs.TabLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_extensions"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />
</LinearLayout>
