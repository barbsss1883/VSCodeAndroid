<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E1E"
    android:orientation="vertical">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/terminal_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1E1E1E"
        app:title="Terminal"
        app:titleTextColor="#CCCCCC"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <!-- Termux status bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="#1A3A1A"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_termux_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#88CC88"
            android:textSize="11sp"
            android:text="Cargando..." />

        <ImageButton
            android:id="@+id/btn_open_termux"
            android:layout_width="80dp"
            android:layout_height="28dp"
            android:background="#2A5A2A"
            android:src="@drawable/ic_terminal"
            android:tint="#88CC88"
            android:contentDescription="Abrir Termux"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Terminal WebView -->
    <WebView
        android:id="@+id/terminal_web_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Special keys toolbar -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#252526"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <Button
                android:id="@+id/btn_key_tab"
                style="@style/TerminalKeyButton"
                android:text="Tab" />

            <Button
                android:id="@+id/btn_key_ctrl_c"
                style="@style/TerminalKeyButton"
                android:text="Ctrl+C" />

            <Button
                android:id="@+id/btn_key_ctrl_d"
                style="@style/TerminalKeyButton"
                android:text="Ctrl+D" />

            <Button
                android:id="@+id/btn_key_esc"
                style="@style/TerminalKeyButton"
                android:text="Esc" />

            <Button
                android:id="@+id/btn_key_up"
                style="@style/TerminalKeyButton"
                android:text="↑" />

            <Button
                android:id="@+id/btn_key_down"
                style="@style/TerminalKeyButton"
                android:text="↓" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btn_clear_terminal"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                android:tint="#888888"
                android:contentDescription="Limpiar terminal" />

            <ImageButton
                android:id="@+id/btn_new_session"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_refresh"
                android:tint="#888888"
                android:contentDescription="Nueva sesión" />
        </LinearLayout>
    </HorizontalScrollView>
</LinearLayout>
